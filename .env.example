# Perpetua-Tools v0.9.9.8 Configuration
# Copy to .env and fill in your actual values

# === PERPLEXITY API (Cloud Models) ===
PERPLEXITY_API_KEY=your_perplexity_api_key_here
# PERPLEXITY_AUTH_MODE=api-key
# Get your key from: https://www.perplexity.ai/settings/api
# If you do not want to use the API yet, setup_wizard.py can record:
PERPLEXITY_AUTH_MODE=web-login
# This marks onboarding complete while keeping programmatic cloud calls disabled.
# Free tier: Limited calls, then $5/month for 1K searches
# Optional client overrides live in code / smoke tests:
#   python scripts/test_perplexity.py --validate --base-url https://api.perplexity.ai --timeout 30
#   PerplexityClient.get(base_url="https://api.perplexity.ai", timeout=30.0)

# === OLLAMA ENDPOINTS (Local Models) ===
OLLAMA_MAC_ENDPOINT=http://192.168.254.103:11434
OLLAMA_WINDOWS_ENDPOINT=http://192.168.254.100:11434
# Adjust IPs to match your LAN setup
# Use localhost:11434 if running on same machine

# === LM STUDIO (v0.9.9.8 canonical local backend) ===
# Win: Qwen3.5-27B Q4_K_M — GPU Offload=40, Context=16384
#      HF: Jackrong/Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2-GGUF
#      Same .gguf loadable in Ollama, koboldcpp, llama.cpp
# Mac: Qwen3.5-9B MLX-4bit — Metal full offload, Context=4096 (conservative M2 16GB)
#      HF: mlx-community/Qwen3.5-9B-MLX-4bit
LM_STUDIO_WIN_ENDPOINTS=http://192.168.254.108:1234,http://192.168.254.100:1234
# Comma-separated for multiple Win agents (max 4):
LM_STUDIO_WIN_ENDPOINTS=http://192.168.1.100:1234,http://192.168.1.101:1234
LM_STUDIO_MAC_ENDPOINT=http://localhost:1234
LMS_WIN_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2
LMS_MAC_MODEL=Qwen3.5-9B-MLX-4bit
LM_STUDIO_API_TOKEN=lmstudio
LM_STUDIO_TIMEOUT=120
# Windows LM Studio autodetect (agent_launcher.py)
# Primary: Qwen3.5-27B (canonical heavy coder / autoresearch lane)
# Secondary: Gemma 4 26B (fallback)
WINDOWS_LMS_PORT=1234
WINDOWS_LMS_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2
WINDOWS_CODER_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2
MAC_MANAGER_MODEL=glm-5.1:cloud
GLM_PROBE_TIMEOUT=8
MODEL_PROBE_TIMEOUT=3
# Known backup fallback model kept documented and routable:
# qwen3.5:35b-a3b-q4_K_M

# === OPENCLAW / ALPHACLAW RUNTIME ===
OPENCLAW_GATEWAY_PORT=18789
ALPHACLAW_INSTALL_DIR=~/.alphaclaw

# === REDIS (State Persistence — v1.1+ for multi-instance deployments) ===
# For MVP single-instance/LAN operation, Redis is NOT required.
# PT uses file-based state (.state/agents.json) by default.
# Redis enables distributed coordination when running multiple PT instances.
REDIS_HOST=192.168.1.100
REDIS_PORT=6379
# Run Redis on your Windows PC or a dedicated server
# Install: docker run -d -p 6379:6379 redis:alpine

# === BUDGET CONTROLS ===
MAX_DAILY_SPEND=0.17
# ~$5/month divided by 30 days = $0.17/day
MAX_PERPLEXITY_CALLS_DAY=5
# Hard limit: 5 cloud calls per day

# === RUNTIME MODE ===
RUNTIME_MODE=lan_full
# Options: mac_only, dell_only, lan_full, lm_studio_mlx
# lan_full = Recommended (uses both Mac + Dell)

# === ORAMA INTEGRATION ===
# orama-system runs on port 8001 (local privacy layer)
# Set ORAMA_ENABLED=true to activate deep reasoning routing
ORAMA_ENDPOINT=http://localhost:8001/orama
ORAMA_TIMEOUT=120
ORAMA_ENABLED=true
# HTTP bridge to orama is always active when routing selects orama
# orama stays stateless - PT owns dedup via .state/agents.json

# MCP-first transport (optional runtime path when configured)
# Unset = HTTP bridge only.
# Set to enable MCP-first transport via subprocess stdio:
# ORAMA_MCP_SERVER_CMD=python /path/to/orama-system/multi_agent/mcp_servers/orama_orchestration_server.py
# When set, PT tries MCP first and falls back to HTTP on failure.

# === ECC-TOOLS INTEGRATION (Optional) ===
# ECC_TOOLS_ENDPOINT=http://localhost:8002/select-model
# Uncomment if using ECC-tools for sub-agent selection

# ECC_SYNC_ENABLED=false
# Set to "false" to skip live git clone/pull of ECC Tools at startup.
# Useful for offline deployments, CI environments, and unit test runs.
# Default: "true" (enabled — pulls latest ECC Tools on every startup).

# === LOGGING ===
LOG_LEVEL=DEBUG
# Options: DEBUG, INFO, WARNING, ERROR

# === OPTIONAL: ALTERNATIVE CLOUD PROVIDERS ===
# Only uncomment if you want to use these instead of Perplexity
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxx
# XAI_API_KEY=xai-xxxxxxxxxxxxx

# === AUTORESEARCH (uditgoenka/autoresearch + Windows GPU runner) ===
# SSH target for Windows RTX 3080 runner
GPU_BOX=WINUSER@192.168.1.100
# Path to autoresearch clone on the Windows runner
GPU_REPO_PATH=autoresearch
# SSH timeout in seconds
SSH_TIMEOUT=90
# Path to autoresearch clone on Mac (local, for git log / swarm_state.md edits)
LOCAL_AUTORESEARCH_PATH=/Users/youruser/autoresearch
# Windows Ollama endpoint (used by models.yml ${DELL_ENDPOINT})
DELL_ENDPOINT=http://192.168.254.100:11434

# === CROSS-REPO PATH (orama-system reads this) ===
# Set by orama-system to locate this repo for cross-repo imports (api_server.py, discover.py).
# Not needed inside PT itself — used externally via sys.path.insert().
# Canonical env var:
PERPETUA_TOOLS_ROOT=/absolute/path/to/Perpetua-Tools
# Legacy aliases used by older scripts in sibling repos:
# PERPETUA_TOOLS_PATH=/absolute/path/to/Perpetua-Tools
# PERPETUATOOLSROOT=/absolute/path/to/Perpetua-Tools
# Uncomment and set if PT is not at the default sibling path ../perplexity-api/Perpetua-Tools
# PERPETUA_TOOLS_ROOT=/absolute/path/to/Perpetua-Tools

# === SESSION-ONLY SECRETS (copy to .env.local - never commit) ===
# Set these in your terminal session, NOT in .env or .env.example:
# export DELL_SSH_KEY=~/.ssh/id_ed25519  # Path to SSH private key for GPU_BOX
# export ANTHROPIC_API_KEY=sk-ant-...    # Claude API key (if using direct Anthropic)
# .env.local is gitignored; see .gitignore
# XAI_API_KEY=xai-xxxxxxxxxxxxx
