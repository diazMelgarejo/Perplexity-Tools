# Perplexity-Tools v0.9.8.0 Configuration
# Copy to .env and fill in your actual values

# === PERPLEXITY API (Cloud Models) ===
PERPLEXITY_API_KEY=your_perplexity_api_key_here
# Get your key from: https://www.perplexity.ai/settings/api
# Free tier: Limited calls, then $5/month for 1K searches

# === OLLAMA ENDPOINTS (Local Models) ===
OLLAMA_MAC_ENDPOINT=http://192.168.1.101:11434
OLLAMA_WINDOWS_ENDPOINT=http://192.168.1.100:11434
# Adjust IPs to match your LAN setup
# Use localhost:11434 if running on same machine

# === LM STUDIO MLX (Alternative - Optional) ===
# MLX_MAC_ENDPOINT=http://localhost:1234
# MLX_WINDOWS_ENDPOINT=http://192.168.1.100:1234
# Uncomment if using LM Studio instead of Ollama

# === REDIS (State Persistence — v1.1+ for multi-instance deployments) ===
# For MVP single-instance/LAN operation, Redis is NOT required.
# PT uses file-based state (.state/agents.json) by default.
# Redis enables distributed coordination when running multiple PT instances.
REDIS_HOST=192.168.1.100
REDIS_PORT=6379
# Run Redis on your Windows PC or a dedicated server
# Install: docker run -d -p 6379:6379 redis:alpine

# === BUDGET CONTROLS ===
MAX_DAILY_SPEND=0.17
# ~$5/month divided by 30 days = $0.17/day
MAX_PERPLEXITY_CALLS_DAY=5
# Hard limit: 5 cloud calls per day

# === RUNTIME MODE ===
RUNTIME_MODE=lan_full
# Options: mac_only, dell_only, lan_full, lm_studio_mlx
# lan_full = Recommended (uses both Mac + Dell)

# === ULTRATHINK INTEGRATION ===
# ultrathink-system runs on port 8001 (local privacy layer)
# Set ULTRATHINK_ENABLED=true to activate deep reasoning routing
ULTRATHINK_ENDPOINT=http://localhost:8001/ultrathink
ULTRATHINK_TIMEOUT=120
ULTRATHINK_ENABLED=true
# HTTP bridge to ultrathink is always active when routing selects ultrathink
# ultrathink stays stateless - PT owns dedup via .state/agents.json

# === ECC-TOOLS INTEGRATION (Optional) ===
# ECC_TOOLS_ENDPOINT=http://localhost:8002/select-model
# Uncomment if using ECC-tools for sub-agent selection

# === LOGGING ===
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# === OPTIONAL: ALTERNATIVE CLOUD PROVIDERS ===
# Only uncomment if you want to use these instead of Perplexity
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxxx
# XAI_API_KEY=xai-xxxxxxxxxxxxx

# === AUTORESEARCH (karpathy/autoresearch + Windows GPU runner) ===
# SSH target for Windows RTX 3080 runner
GPU_BOX=WINUSER@192.168.1.100
# Path to autoresearch clone on the Windows runner
GPU_REPO_PATH=autoresearch
# SSH timeout in seconds
SSH_TIMEOUT=90
# Path to autoresearch clone on Mac (local, for git log / swarm_state.md edits)
LOCAL_AUTORESEARCH_PATH=/Users/youruser/autoresearch
# Windows Ollama endpoint (used by models.yml ${DELL_ENDPOINT})
DELL_ENDPOINT=http://192.168.1.100

# === SESSION-ONLY SECRETS (copy to .env.local - never commit) ===
# Set these in your terminal session, NOT in .env or .env.example:
# export DELL_SSH_KEY=~/.ssh/id_ed25519  # Path to SSH private key for GPU_BOX
# export ANTHROPIC_API_KEY=sk-ant-...    # Claude API key (if using direct Anthropic)
# .env.local is gitignored; see .gitignore
# XAI_API_KEY=xai-xxxxxxxxxxxxx
