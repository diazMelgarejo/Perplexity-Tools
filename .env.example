# Perplexity-Tools v1.0.0-rc Configuration
# Copy to .env and fill in your values

# === API SERVER ===
API_HOST=0.0.0.0
API_PORT=8000

# === ORCHESTRATOR ===
ULTRATHINK_ENDPOINT=http://localhost:8001

# === PERPLEXITY API ===
PERPLEXITY_API_KEY=
PERPLEXITY_TIMEOUT=120

# === LM STUDIO (v1.0 RC — Primary Local Backends) ===
# Mac = Orchestrator/Validator | Windows = Agent(s)
LM_STUDIO_MAC_ENDPOINT=http://192.168.1.101:1234
LMS_MAC_MODEL=Qwen3.5-9B-MLX-4bit
LMS_MAC_CONTEXT=4096   # conservative, M2 16GB

LM_STUDIO_WIN_ENDPOINTS=http://192.168.1.100:1234
# Multiple Win agents: http://192.168.1.100:1234,http://192.168.1.102:1234 (max 4)
LMS_WIN_MAX_PARALLEL=4
LMS_WIN_MODEL=Qwen3.5-27B-Claude-4.6-Opus-Reasoning-Distilled-v2
# .gguf file also compatible with Ollama, koboldcpp — backend-agnostic

LM_STUDIO_API_TOKEN=

# === OLLAMA (Fallback) ===
OLLAMA_HOST=http://127.0.0.1:11434

# === SECURITY ===
ALLOWED_HOSTS=*
# * = allow all (dev default). Set to comma-separated list in production.

# === LOGGING ===
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR

# === SESSION-ONLY SECRETS (copy to .env.local - never commit) ===
# Add API keys here if needed (not recommended — local models preferred)
