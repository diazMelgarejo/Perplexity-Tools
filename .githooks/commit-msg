#!/usr/bin/env bash
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
MSG="${1:?commit message file required}"

"$ROOT/scripts/git/ensure_hooks_installed.sh"

# Strip Cursor-injected trailers before policy validation.
if [[ -x "$ROOT/scripts/git/hooks/commit-msg.strip-coauthor" ]]; then
  "$ROOT/scripts/git/hooks/commit-msg.strip-coauthor" "$MSG"
fi

exec "$ROOT/scripts/git/check_commit_message.sh" "$MSG"
